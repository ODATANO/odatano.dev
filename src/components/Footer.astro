---
import logoUrl from "../assets/logo_O_v6_split.svg?url";
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <img src={logoUrl} alt="ODATANO" height="28" />
      <p>Enterprise OData V4 for the Cardano Blockchain</p>
    </div>
    <nav
      class="site-footer__links site-footer__links--content"
      aria-label="Site navigation"
    >
      <a href="/docs/quick-start/">Quick Start</a>
      <a href="/docs/trace/">TRACE App</a>
      <a href="/docs/quantix/">QUANTIX App</a>
      <a href="/docs/reference/">API Reference</a>
      <a
        href="https://github.com/ODATANO/ODATANO"
        target="_blank"
        rel="noopener">GitHub</a
      >
    </nav>
    <nav
      class="site-footer__links site-footer__links--legal"
      aria-label="Legal"
    >
      <a href="/imprint/">Imprint</a>
      <a href="/privacy/">Privacy</a>
    </nav>
    <p class="site-footer__copy">&copy; 2026 ODATANO</p>
  </div>
</footer>
