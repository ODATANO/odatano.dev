          <textarea name="message" placeholder="Your message" rows="4" required aria-label="Your message"></textarea>
          <button type="submit" class="btn btn--night btn--lg">Send message</button>
          <p class="contact__status" role="status" aria-live="polite"></p>
        </form>
      </div>
    </div>
