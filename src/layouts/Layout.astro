---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Enterprise OData V4 Service for the Cardano Blockchain built on SAP CAP.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>ODATANO - {title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:title" content={`ODATANO ${title}`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content="https://odatano.dev/og-image.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`ODATANO ${title}`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://odatano.dev/og-image.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      // Progressive enhancement: scroll-reveal + cursor spotlight.
      // No-op (content stays fully visible) without JS or with reduced motion.
      (() => {
        const root = document.documentElement;
        const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        // Cursor spotlight — works regardless of motion preference.
        const spotlightEls = document.querySelectorAll<HTMLElement>(
          ".feature-card, .example-card, .stack__item, .arch__col"
        );
        spotlightEls.forEach((el) => {
          el.addEventListener("pointermove", (ev) => {
            const pe = ev as PointerEvent;
            const r = el.getBoundingClientRect();
            el.style.setProperty("--mx", pe.clientX - r.left + "px");
            el.style.setProperty("--my", pe.clientY - r.top + "px");
          });
        });

        if (reduce) return;
        root.classList.add("reveal-ready");

        const els = Array.from(
          document.querySelectorAll<HTMLElement>(
            ".section__header, .feature-card, .arch__col, .stack__item, .step, .example-card, .code-demo__panel, .stats-bar__item"
          )
        );
        els.forEach((el) => el.setAttribute("data-reveal", ""));

        // Stagger reveal of siblings sharing a parent.
        const groups = new Map<Element | null, HTMLElement[]>();
        els.forEach((el) => {
          const arr = groups.get(el.parentElement) || [];
          arr.push(el);
          groups.set(el.parentElement, arr);
        });
        groups.forEach((arr) =>
          arr.forEach((el, i) =>
            el.style.setProperty("--reveal-delay", i * 70 + "ms")
          )
        );

        if (!("IntersectionObserver" in window)) {
          els.forEach((el) => el.classList.add("is-visible"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                io.unobserve(e.target);
              }
            });
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.08 }
        );
        els.forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>
